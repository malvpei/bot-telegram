TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Carpeta persistente del bot: memoria de fotos usadas, cache, outputs y estado.
# En Docker/Coolify el Dockerfile y docker-compose la fuerzan a /app/data.
# En local puedes dejarlo vacio para usar ./data.
DATA_DIR=

INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Alternativa sin login: pega aquí las cookies de tu sesión de Instagram
# (desde el navegador donde tengas IG abierto: F12 -> Application ->
# Cookies -> instagram.com). Con esto el bot no pide usuario/contraseña
# y evita el 429 anónimo.
IG_SESSIONID=
IG_DS_USER_ID=
IG_CSRFTOKEN=
# Si tienes 2FA o quieres evitar logins repetidos, deja un session file de
# instaloader aquí (default: data/state/instagram_session/<usuario>).
INSTAGRAM_SESSION_PATH=

FIXED_IMAGE_PATH=

# Archivo con las cuentas de Instagram que el bot usará, una por línea.
# Default: bot-telegram/accounts.txt
ACCOUNTS_FILE=

MAX_POSTS_PER_ACCOUNT=100
MAX_URLS_PER_JOB=8

# Pool precargado: /download_pool rellena fotos aptas y /create consume de aqui.
POOL_TARGET_IMAGES=50
POOL_LOW_STOCK_THRESHOLD=12
ACCOUNT_COOLDOWN_DAYS=30

VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
SLIDE_SECONDS=3.8
TRANSITION_SECONDS=0.35

# Telegram bots tienen un límite real de 50 MB. Si el render supera este valor
# se vuelve a codificar con un CRF más alto antes de enviarlo.
MAX_VIDEO_SIZE_MB=48

# Cuántas firmas de guion guardar por (tipo, idioma) antes de empezar a
# rotarlas para que el dedup no degenere.
HISTORY_MAX_PER_BUCKET=200

# Reintentos y backoff exponencial para descargas individuales del CDN de IG.
DOWNLOAD_RETRIES=3
DOWNLOAD_BACKOFF_SECONDS=1.5

# Borrar carpetas de output más antiguas que esto. 0 desactiva la limpieza.
OUTPUT_RETENTION_DAYS=7

# Cuánto tiempo reutilizar las imágenes ya descargadas de una cuenta sin
# volver a pegarle a Instagram. 0 = permanente: descargar una vez y elegir
# siempre desde data/downloads/<cuenta>.
ACCOUNT_CACHE_TTL_HOURS=0

# Máximo de cuentas a probar por /create. El bot elige aleatoriamente; si
# la primera falla (rate limit, privada, etc.) sigue con la siguiente.
# 0 = modo normal, rotando cuentas y evitando falsos agotamientos.
ACCOUNT_PICK_ATTEMPTS=0
